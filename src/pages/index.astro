---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.tsx'
import CumulativeCounter from '../components/CumulativeCounter.tsx'
import DailyChanges from '../components/DailyChanges.tsx'
import StreakBanner from '../components/StreakBanner.tsx'
import TriviaStrip from '../components/TriviaStrip.tsx'
import PollCard from '../components/PollCard.tsx'
import StoryCard from '../components/StoryCard.tsx'
import BottomNav from '../components/BottomNav.tsx'
import Ticker from '../components/Ticker.tsx'

import monthlyData from '../data/monthly.json'
import weeklyData from '../data/weekly.json'

const monthly = monthlyData.items
const weekly = weeklyData.items
---

<BaseLayout>
  <!-- ① Header: client:load は new Date() で今日の日付を表示するために必要 -->
  <Header client:load />

  <!-- ティッカーバー: 静的データのため client:* 不要 -->
  <Ticker />

  <main class="max-w-lg mx-auto pb-24">
    <!-- ② 累計カウンター -->
    <CumulativeCounter client:load />

    <!-- ③ きのう→きょう -->
    <DailyChanges client:visible />

    <!-- ④ ストリークバナー -->
    <StreakBanner client:visible />

    <!-- ⑤ トリビア帯 -->
    <TriviaStrip
      text="3年前は198円だった卵パック、今は309円で過去最高値更新中。毎日食べるなら月2,000円以上の差。"
      emoji="🥚"
      client:visible
    />

    <!-- ⑥ 投票カード -->
    <PollCard
      id="bukka_2026q1"
      question="物価上昇、一番キツいのは？"
      options={["食費（卵・野菜）", "電気・ガス代", "ガソリン代", "住宅ローン金利"]}
      client:visible
    />

    <!-- ⑦ ストーリーカード：電気代（PR） -->
    {/* TODO: ctaUrl に A8.net 等のアフィリエイトURLを設定する（エネチェンジ案件） */}
    <StoryCard
      id="denki"
      label="電気代（月平均）"
      current={monthly.denki.current}
      previous={monthly.denki.year_ago}
      unit="円"
      diffPct={monthly.denki.diff_pct}
      direction={monthly.denki.direction}
      equivalent={`年間で約${(monthly.denki.diff * 12).toLocaleString()}円の差`}
      ctaText="電力会社を比較してみる"
      ctaUrl="#"
      isPR={true}
      accentColor="orange"
      client:visible
    />

    <!-- ⑧ トリビア帯 -->
    <TriviaStrip
      text="食費の平均は月3,800円増。年間で約46,000円、旅行1回分が消えた計算。"
      emoji="🍽️"
      client:visible
    />

    <!-- ⑨ ストーリーカード：給料（PR） -->
    {/* TODO: ctaUrl に A8.net 等のアフィリエイトURLを設定する（マネーフォワード案件） */}
    <StoryCard
      id="cpi"
      label="手取りの実質価値"
      current="前年比 +1.4%"
      previous="前年比 −2.1%"
      unit=""
      diffPct={3.5}
      direction="up"
      equivalent="13ヶ月ぶりのプラス転換。でも物価上昇で累積損失は回収できていない"
      ctaText="市場価値を診断する"
      ctaUrl="https://ck.jp.ap.valuecommerce.com/servlet/referral?sid=3766489&pid=892580436"
      isPR={true}
      accentColor="purple"
      client:visible
    />

    <!-- ⑩ トリビア帯 -->
    <TriviaStrip
      text="日本のビッグマックは450円。アメリカでは約850円。同じバーガーなのに。"
      emoji="🍔"
      client:visible
    />

    <!-- ⑪ ストーリーカード：NISA（PR） -->
    {/* TODO: ctaUrl に A8.net 等のアフィリエイトURLを設定する（SBI証券 / 楽天証券案件） */}
    <StoryCard
      id="nisa"
      label="NISAやってない人の機会損失"
      current="年間約5.4万円"
      previous="0円"
      unit=""
      diffPct={0}
      direction="up"
      equivalent="年間5.4万円、旅行1回分の差がつきます"
      ctaText="NISAについてFPに無料相談"
      ctaUrl="https://af.moshimo.com/af/c/click?a_id=5452995&p_id=7356&pc_id=21162&pl_id=92571"
      isPR={true}
      accentColor="blue"
      client:visible
    />

    <!-- ⑫ ストーリーカード：ガソリン（PR） -->
    {/* TODO: ctaUrl に A8.net 等のアフィリエイトURLを設定する（自動車保険一括比較案件） */}
    <StoryCard
      id="gasoline"
      label={weekly.gasoline.label}
      current={weekly.gasoline.current}
      previous={weekly.gasoline.year_ago}
      unit={weekly.gasoline.unit}
      diffPct={weekly.gasoline.diff_year_pct}
      direction={weekly.gasoline.direction}
      equivalent={`満タン(50L)で約${((weekly.gasoline.current - weekly.gasoline.year_ago) * 50).toLocaleString()}円の差`}
      ctaText="自動車保険を一括比較"
      ctaUrl="#"
      isPR={true}
      accentColor="red"
      client:visible
    />

    <!-- ⑬ トリビア帯 -->
    <TriviaStrip
      text="このペースが続くと2029年に卵1パック500円を超える計算。お弁当どうする？"
      emoji="📈"
      client:visible
    />
  </main>

  <!-- ⑭ BottomNav: 静的リンクのみのため client:load 不要（ビルド時に静的HTML生成） -->
  <BottomNav />
</BaseLayout>
